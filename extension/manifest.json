{
  "manifest_version": 3,
  "name": "IBF Comic Translator Local",
  "version": "0.3.0",
  "description": "Переводит изображения на странице браузера",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_title": "Comic Translator Settings",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  }
}
